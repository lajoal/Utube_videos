{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/lajoal/Utube_videos/blob/main/schemas/self_check_summary.schema.json",
  "title": "Self Check Summary",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "generated_at",
    "started_at",
    "finished_at",
    "duration_seconds",
    "repo_root",
    "python_executable",
    "keep_going",
    "skip_tests",
    "skip_report",
    "reporting_output_path",
    "reporting_markdown_output_path",
    "reporting_output_exists",
    "reporting_markdown_output_exists",
    "self_check_summary_path",
    "self_check_summary_markdown_path",
    "selected_step_count",
    "completed_step_count",
    "failed_step_count",
    "skipped_step_count",
    "passed_steps",
    "failed_steps",
    "skipped_steps",
    "artifacts",
    "overall_passed",
    "overall_status",
    "exit_code",
    "steps"
  ],
  "properties": {
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "finished_at": {
      "type": "string",
      "format": "date-time"
    },
    "duration_seconds": {
      "type": "number",
      "minimum": 0
    },
    "repo_root": {
      "type": "string"
    },
    "python_executable": {
      "type": "string"
    },
    "keep_going": {
      "type": "boolean"
    },
    "skip_tests": {
      "type": "boolean"
    },
    "skip_report": {
      "type": "boolean"
    },
    "reporting_output_path": {
      "type": ["string", "null"]
    },
    "reporting_markdown_output_path": {
      "type": ["string", "null"]
    },
    "reporting_output_exists": {
      "type": ["boolean", "null"]
    },
    "reporting_markdown_output_exists": {
      "type": ["boolean", "null"]
    },
    "self_check_summary_path": {
      "type": "string"
    },
    "self_check_summary_markdown_path": {
      "type": "string"
    },
    "selected_step_count": {
      "type": "integer",
      "minimum": 0
    },
    "completed_step_count": {
      "type": "integer",
      "minimum": 0
    },
    "failed_step_count": {
      "type": "integer",
      "minimum": 0
    },
    "skipped_step_count": {
      "type": "integer",
      "minimum": 0
    },
    "passed_steps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "failed_steps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "skipped_steps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reporting_json",
        "reporting_markdown",
        "self_check_json",
        "self_check_markdown"
      ],
      "properties": {
        "reporting_json": {
          "anyOf": [
            { "$ref": "#/$defs/artifactRecord" },
            { "type": "null" }
          ]
        },
        "reporting_markdown": {
          "anyOf": [
            { "$ref": "#/$defs/artifactRecord" },
            { "type": "null" }
          ]
        },
        "self_check_json": {
          "$ref": "#/$defs/artifactRecord"
        },
        "self_check_markdown": {
          "$ref": "#/$defs/artifactRecord"
        }
      }
    },
    "overall_passed": {
      "type": "boolean"
    },
    "overall_status": {
      "type": "string",
      "enum": ["pass", "fail"]
    },
    "exit_code": {
      "type": "integer",
      "minimum": 0
    },
    "steps": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/stepResult"
      }
    }
  },
  "$defs": {
    "artifactRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "exists",
        "size_bytes"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "exists": {
          "type": "boolean"
        },
        "size_bytes": {
          "type": ["integer", "null"],
          "minimum": 0
        }
      }
    },
    "stepResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "command",
        "command_display",
        "status",
        "exit_code",
        "started_at",
        "finished_at",
        "duration_seconds"
      ],
      "properties": {
        "label": {
          "type": "string"
        },
        "command": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "command_display": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": ["passed", "failed", "skipped"]
        },
        "exit_code": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "started_at": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "finished_at": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "duration_seconds": {
          "type": ["number", "null"],
          "minimum": 0
        }
      }
    }
  }
}
